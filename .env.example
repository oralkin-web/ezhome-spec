# База данных PostgreSQL (Railway даёт автоматически)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Секрет сессий — придумай длинную случайную строку, минимум 32 символа
# Генератор: openssl rand -base64 32
SESSION_SECRET=замени-на-случайную-строку-минимум-32-символа

# Токен инвайта — должен совпадать с URL на лендинге (/invite/<токен>)
INVITE_TOKEN=seta-beta-2026

# Resend API для отправки писем (resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# URL приложения (используется в ссылках в письмах)
APP_URL=https://app.useseta.com

# Режим окружения — обязательно 'production' на сервере
NODE_ENV=production
